# ─────────────────────────────────────────────────────────
#  ExpensePro — .gitignore
# ─────────────────────────────────────────────────────────

# ── Virtual Environment ──────────────────────────────────
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ── Python Compiled Files ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Django Specific ──────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Media files uploaded by users (receipts, etc.)
media/

# Django static collected output (production)
staticfiles/
static_root/

# ── Migrations (optional — keep if sharing DB schema) ────
# Uncomment the line below ONLY if you want to ignore migrations
# ExpenseProject/ExpenseApp/migrations/

# ── Environment Variables / Secrets ─────────────────────
.env
.env.*
*.env
secrets.py
local_settings.py

# ── Distribution / Packaging ────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/

# ── Testing ──────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
pytest.ini
nosetests.xml
coverage.xml
*.cover

# ── Type Checkers ────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# ── Jupyter / IPython ────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── VS Code ──────────────────────────────────────────────
.vscode/
*.code-workspace

# ── PyCharm / JetBrains ──────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── Windows OS Files ─────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── macOS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Node (if any frontend tooling is added later) ────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Miscellaneous ────────────────────────────────────────
*.bak
*.swp
*.swo
*~
*.orig
